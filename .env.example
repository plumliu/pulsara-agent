PULSARA_API_KEY=sk-your-api-key
PULSARA_BASE_URL=https://api.openai.com/v1
PULSARA_PRO_MODEL=gpt-5
PULSARA_FLASH_MODEL=gpt-5-mini
# accept_reported supports provider aliases/snapshots; use exact only when the
# provider guarantees it echoes the requested model id.
PULSARA_MODEL_IDENTITY_POLICY=accept_reported
# Both model slots default to a 256k context contract. The
# PULSARA_{PRO,FLASH}_{TOTAL_CONTEXT,MAX_INPUT,MAX_OUTPUT,DEFAULT_OUTPUT,
# INPUT_SAFETY_MARGIN}_TOKENS variables remain available for provider-specific
# overrides, but ordinary deployments do not need to set them.

PULSARA_RERANK_API_KEY=sk-your-dashscope-api-key
PULSARA_EMBEDDING_API_KEY=sk-your-dashscope-api-key

PULSARA_OXIGRAPH_URL=http://localhost:7878
# The admin DSN is consumed only by `pulsara db migrate`. Host/runtime paths
# use the restricted runtime role and never auto-migrate.
PULSARA_POSTGRES_ADMIN_DSN=postgresql://pulsara_admin:pulsara_admin@localhost:5432/pulsara
PULSARA_POSTGRES_DSN=postgresql://pulsara_runtime:pulsara_runtime@localhost:5432/pulsara

# Docker role-genesis inputs. Change these together with the DSNs above when
# using the bundled compose file on a fresh database volume.
PULSARA_POSTGRES_ADMIN_PASSWORD=pulsara_admin
PULSARA_POSTGRES_RUNTIME_PASSWORD=pulsara_runtime
